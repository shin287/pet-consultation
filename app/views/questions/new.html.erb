<h1>質問する</h1>

<%= form_with model: @question do |f| %>
  <p>
    タイトル<br>
    <%= f.text_field :title %>
  </p>

  <p>
    カテゴリ<br>
    <%= f.text_field :category %>
  </p>

  <p>
    相談内容<br>
    <%= f.text_area :body %>
  </p>

  <p>
    <%= f.submit "投稿する" %>
  </p>
<% end %>

<%= link_to "質問一覧へ", questions_path %>


