<main class="page page-form">
  <section class="form-card">
    <h1>質問を編集</h1>

    <%= form_with model: @question, class: "basic-form" do |f| %>
      <% if @question.answers.any? %>
        <p class="notice-text">回答がついているため、質問内容は変更できません。追記のみ可能です。</p>

        <div class="form-field">
          <%= f.label :additional_info, "追記" %>
          <%= f.text_area :additional_info %>
        </div>
      <% else %>
        <div class="form-field">
          <%= f.label :title, "タイトル" %>
          <%= f.text_field :title %>
        </div>

        <div class="readonly-field">
          <span>カテゴリ</span>
          <p><%= @question.animal_type %> / <%= @question.consultation_type %></p>
        </div>

        <div class="form-field">
          <%= f.label :body, "相談内容" %>
          <%= f.text_area :body %>
        </div>

        <div class="form-field">
          <%= f.label :additional_info, "追記" %>
          <%= f.text_area :additional_info %>
        </div>
      <% end %>

      <div class="form-submit">
        <%= f.submit "更新する" %>
      </div>
    <% end %>
  </section>

  <div class="page-actions">
    <%= link_to "詳細へ戻る", question_path(@question) %>
  </div>
</main>
